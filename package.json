{
  "name": "coffee-pos-system",
  "version": "2.0.0",
  "description": "Coffee POS System - Modern Express.js Point of Sale for Coffee Shops with REST API, SQLite, and Real-time Sync",
  "main": "server.js",
  "scripts": {
    "start": "npm run dev",
    "dev": "nodemon server.js",
    "production": "NODE_ENV=production node server.js",
    "setup": "npm install && node migrate-db.js",
    "backup-db": "node scripts/backup-database.js",
    "health-check": "curl -f http://localhost:3000/api/health || exit 1",
    "security-check": "npm audit --production",
    "clean": "rimraf logs/*.log backups/*.db",
    "postinstall": "echo \"Installation complete! Run 'npm start' to start the server.\"",
    "test": "echo \"No tests specified\" && exit 0"
  },
  "keywords": [
    "pos",
    "coffee",
    "point-of-sale",
    "sqlite",
    "express",
    "rest-api",
    "real-time",
    "socket.io",
    "khmer",
    "cambodia",
    "mvc",
    "modular"
  ],
  "author": "Coffee POS System",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.0",
    "helmet": "^7.1.0",
    "morgan": "^1.10.1",
    "socket.io": "^4.8.3",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=6.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/coffee-pos-system"
  },
  "bugs": {
    "url": "https://github.com/yourusername/coffee-pos-system/issues"
  },
  "homepage": "https://github.com/yourusername/coffee-pos-system#readme"
}
